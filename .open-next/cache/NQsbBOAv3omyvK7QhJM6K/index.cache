w.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone w-4 h-4 text-brand-teal\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"></path></svg> +52 833 111 2410</div></div><div class=\"absolute bottom-0 left-0 bg-brand-navy text-white rounded-xl px-4 py-3 shadow-xl\"><div class=\"text-xs opacity-60 uppercase tracking-wider font-semibold\">Cobertura</div><div class=\"font-black text-lg\">Nacional</div></div></div></div></div></section><section id=\"nosotros\" class=\"relative py-24 bg-white overflow-hidden\"><div class=\"absolute top-0 right-0 pointer-events-none overflow-hidden opacity-60\" aria-hidden=\"true\"><svg width=\"140\" height=\"140\" viewBox=\"0 0 140 140\" fill=\"none\"><polygon points=\"70,0 140,0 140,70\" fill=\"#1D3F5E\" opacity=\"0.13\"></polygon><polygon points=\"100,0 140,0 140,40\" fill=\"#1D3F5E\" opacity=\"0.2\"></polygon></svg></div><div class=\"container-brand\"><div class=\"grid md:grid-cols-2 gap-16 items-start\"><div><p class=\"section-eyebrow\">¿Quiénes somos?</p><h2 class=\"section-title\">Su proveedor <span class=\"text-brand-teal\">confiable</span></h2><p class=\"mt-5 text-gray-600 text-lg leading-relaxed\">Somos su aliado confiable en el suministro de productos de<!-- --> <strong>higiene y seguridad industrial</strong> y cualquier otro insumo que su negocio necesite.</p><p class=\"mt-3 text-gray-600 leading-relaxed\">Ofrecemos soluciones rápidas, de calidad y adaptadas a sus requerimientos, para que usted pueda enfocarse en lo más importante: hacer crecer su empresa.</p><a href=\"#contacto\" class=\"items-center justify-center gap-2 whitespace-nowrap rounded-lg font-bold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-brand-teal text-white hover:bg-brand-teal-dark h-12 px-8 text-base mt-7 inline-flex\">Contáctenos hoy <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div><div class=\"space-y-5\"><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm border-l-4 border-l-brand-teal\"><div class=\"p-6 pt-5\"><div class=\"flex items-center gap-3 mb-3\"><div class=\"w-9 h-9 rounded-lg flex items-center justify-center bg-brand-teal\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-star w-4 h-4 text-white\"><path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z\"></path></svg></div><span class=\"text-xs font-black text-brand-navy uppercase tracking-widest\">NUESTRA MISIÓN</span></div><p class=\"text-sm text-gray-600 leading-relaxed\">Proporcionar a las empresas productos de higiene y seguridad industrial y todo tipo de insumos con rapidez, calidad y atención personalizada. Ofreciendo soluciones confiables y adaptadas a las necesidades de cada cliente.</p></div></div><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm border-l-4 border-l-brand-navy\"><div class=\"p-6 pt-5\"><div class=\"flex items-center gap-3 mb-3\"><div class=\"w-9 h-9 rounded-lg flex items-center justify-center bg-brand-navy\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe w-4 h-4 text-white\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg></div><span class=\"text-xs font-black text-brand-navy uppercase tracking-widest\">NUESTRA VISIÓN</span></div><p class=\"text-sm text-gray-600 leading-relaxed\">Convertirnos en el líder a nivel nacional en la distribución y comercialización de insumos de higiene y seguridad industrial. Buscamos ser reconocidos como la mejor opción en calidad y precio, estableciendo relaciones duraderas y de confianza.</p></div></div></div></div></div></section><section id=\"valores\" class=\"relative py-24 bg-brand-light-blue overflow-hidden\"><div class=\"absolute bottom-0 left-0 pointer-events-none overflow-hidden\" aria-hidden=\"true\"><svg width=\"120\" height=\"120\" viewBox=\"0 0 120 120\" fill=\"none\"><polygon points=\"0,60 60,120 0,120\" fill=\"#3BBFC0\" opacity=\"0.12\"></polygon></svg></div><div class=\"container-brand\"><div class=\"text-center mb-14\"><p class=\"section-eyebrow\">Lo que nos define</p><h2 class=\"section-title\">Nuestros <span class=\"text-brand-teal\">Valores</span></h2></div><div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-6\"><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm group hover:shadow-lg transition-all duration-300 hover:-translate-y-1\"><div class=\"p-6 pt-6\"><div class=\"w-11 h-11 bg-brand-navy text-white rounded-lg flex items-center justify-center font-black text-base mb-4 group-hover:bg-brand-teal transition-colors\">01</div><h3 class=\"font-black text-brand-navy text-lg mb-2\">Confianza</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Generando un clima de cercanía a través de una comunicación clara, personalizada y transparente.</p></div></div><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm group hover:shadow-lg transition-all duration-300 hover:-translate-y-1\"><div class=\"p-6 pt-6\"><div class=\"w-11 h-11 bg-brand-navy text-white rounded-lg flex items-center justify-center font-black text-base mb-4 group-hover:bg-brand-teal transition-colors\">02</div><h3 class=\"font-black text-brand-navy text-lg mb-2\">Empatía</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Entendiendo y conociendo a nuestros clientes. Sintiéndonos parte de una alianza común en torno a un objetivo compartido.</p></div></div><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm group hover:shadow-lg transition-all duration-300 hover:-translate-y-1\"><div class=\"p-6 pt-6\"><div class=\"w-11 h-11 bg-brand-navy text-white rounded-lg flex items-center justify-center font-black text-base mb-4 group-hover:bg-brand-teal transition-colors\">03</div><h3 class=\"font-black text-brand-navy text-lg mb-2\">Excelencia</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Cumpliendo lo prometido, superando expectativas y cuidando cada detalle para asegurar un servicio eficiente y soluciones efectivas.</p></div></div><div class=\"rounded-xl border border-gray-100 bg-white shadow-sm group hover:shadow-lg transition-all duration-300 hover:-translate-y-1\"><div class=\"p-6 pt-6\"><div class=\"w-11 h-11 bg-brand-navy text-white rounded-lg flex items-center justify-center font-black text-base mb-4 group-hover:bg-brand-teal transition-colors\">04</div><h3 class=\"font-black text-brand-navy text-lg mb-2\">Integridad</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Privilegiando los intereses y la confidencialidad de la información de nuestros clientes, cuidando a nuestro personal.</p></div></div></div></div></section><section class=\"relative py-24 bg-brand-navy overflow-hidden\"><div class=\"container-brand\"><div class=\"text-center mb-14\"><p class=\"text-brand-teal font-bold text-xs uppercase tracking-widest mb-2\">¿Por qué elegirnos?</p><h2 class=\"text-3xl sm:text-4xl font-black uppercase text-white tracking-tight\">Ventajas <span class=\"text-brand-teal\">Competitivas</span></h2></div><div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"text-center group\"><div class=\"w-16 h-16 bg-brand-teal/10 border border-brand-teal/30 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-teal transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shopping-bag w-7 h-7 text-brand-teal group-hover:text-white transition-colors duration-300\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z\"></path><path d=\"M3 6h18\"></path><path d=\"M16 10a4 4 0 0 1-8 0\"></path></svg></div><h3 class=\"font-bold text-white text-sm mb-2\">Amplia gama en un solo proveedor</h3><p class=\"text-gray-400 text-sm leading-relaxed\">EPP, calzado, cocina, limpieza y más, sin necesidad de múltiples proveedores.</p></div><div class=\"text-center group\"><div class=\"w-16 h-16 bg-brand-teal/10 border border-brand-teal/30 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-teal transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-star w-7 h-7 text-brand-teal group-hover:text-white transition-colors duration-300\"><path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z\"></path></svg></div><h3 class=\"font-bold text-white text-sm mb-2\">Precios competitivos</h3><p class=\"text-gray-400 text-sm leading-relaxed\">Precios justos sin comprometer la calidad. Nuestra promesa desde el día uno.</p></div><div class=\"text-center group\"><div class=\"w-16 h-16 bg-brand-teal/10 border border-brand-teal/30 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-teal transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck w-7 h-7 text-brand-teal group-hover:text-white transition-colors duration-300\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg></div><h3 class=\"font-bold text-white text-sm mb-2\">Respuesta rápida</h3><p class=\"text-gray-400 text-sm leading-relaxed\">Su operación no puede esperar. Actuamos con rapidez y cumplimos los tiempos.</p></div><div class=\"text-center group\"><div class=\"w-16 h-16 bg-brand-teal/10 border border-brand-teal/30 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-teal transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users w-7 h-7 text-brand-teal group-hover:text-white transition-colors duration-300\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><h3 class=\"font-bold text-white text-sm mb-2\">Asesoría personalizada</h3><p class=\"text-gray-400 text-sm leading-relaxed\">Le ayudamos a identificar los productos correctos para su operación específica.</p></div></div></div></section><section id=\"clientes\" class=\"relative py-24 bg-brand-light-blue overflow-hidden\"><div class=\"absolute top-0 right-0 pointer-events-none overflow-hidden opacity-60\" aria-hidden=\"true\"><svg width=\"140\" height=\"140\" viewBox=\"0 0 140 140\" fill=\"none\"><polygon points=\"70,0 140,0 140,70\" fill=\"#1D3F5E\" opacity=\"0.13\"></polygon><polygon points=\"100,0 140,0 140,40\" fill=\"#1D3F5E\" opacity=\"0.2\"></polygon></svg></div><div class=\"container-brand\"><div class=\"grid md:grid-cols-2 gap-16 items-center\"><div><p class=\"section-eyebrow\">A quiénes servimos</p><h2 class=\"section-title\">Nuestros <span class=\"text-brand-teal\">Clientes</span></h2><p class=\"mt-4 text-gray-600 leading-relaxed\">Atendemos empresas de diversos sectores que buscan un proveedor confiable para el suministro de productos de higiene, seguridad industrial y cualquier otro insumo que requieran para su operación.</p><p class=\"mt-3 text-gray-600 leading-relaxed\">Desde pequeñas y medianas empresas hasta grandes corporativos, todos confían en nosotros por nuestra capacidad de ofrecer<!-- --> <strong>soluciones rápidas, de calidad y adaptadas</strong> a sus necesidades.</p></div><div class=\"flex flex-col gap-2.5\"><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Industrias manufactureras</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Empresas constructoras</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Hospitales y clínicas</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Restaurantes y alimentos</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Instituciones educativas</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Comercios y retail</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Empresas de servicios</div><div class=\"flex items-center gap-3 bg-white rounded-lg px-4 py-3 shadow-sm text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-brand-teal flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Grandes corporativos</div></div></div></div></section><section id=\"contacto\" class=\"relative py-24 bg-white overflow-hidden\"><div class=\"absolute bottom-0 left-0 pointer-events-none overflow-hidden opacity-60\" aria-hidden=\"true\"><svg width=\"120\" height=\"120\" viewBox=\"0 0 120 120\" fill=\"none\"><polygon points=\"0,60 60,120 0,120\" fill=\"#